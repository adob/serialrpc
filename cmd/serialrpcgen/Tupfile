: foreach *.proto |> protoc --cpp_out=. %B.proto |> %B.pb.h %B.pb.cc

: foreach test_data/*.proto |> protoc \
    --plugin=protoc-gen-serialrpc=$HOME/bin/serialrpcgen \
    --serialrpc_out=test_data/ \
    -I=test_data \
    -I=$HOME/deps/amp-embedded-infra-lib/protobuf/echo_attributes \
    %B.proto |> test_data/%B.pb_client.h test_data/%B.pb_client.cc test_data/%B.pb_server.h test_data/%B.pb_server.cc test_data/%B.pb_msg.h test_data/%B.pb_msg.cc