: foreach example.proto serialrpc_protocol.proto \
    |> protoc --plugin=protoc-gen-serialrpc=$HOME/bin/serialrpcgen_plugin --serialrpc_out=generated -I=. -I=$HOME/deps/amp-embedded-infra-lib/protobuf/echo_attributes %B.proto \
    |> generated/%B.pb_client.h generated/%B.pb_client.cc generated/%B.pb_server.h generated/%B.pb_server.cc generated/%B.pb_msg.h generated/%B.pb_msg.cc


: serialrpc.proto |> protoc --cpp_out=generated %B.proto |> generated/%B.pb.h generated/%B.pb.cc